# Django
DEBUG=False
SECRET_KEY=change-me-in-production-use-a-long-random-string
ALLOWED_HOSTS=localhost,127.0.0.1,app.fabregad.com.ar

# Database
# Local:
DATABASE_URL=sqlite:///db.sqlite3
# Producción (Coolify/Postgres):
# DATABASE_URL=postgres://user:pass@host:5432/fabreapp

# App URLs
APP_BASE_URL=https://app.fabregad.com.ar
APPLICATION_NAME=fabrenaque

# Google Calendar — OAuth
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=https://app.fabregad.com.ar/integraciones/google/callback/

# Alternativa: service account (opcional)
GOOGLE_CALENDAR_ENABLED=False
GOOGLE_SERVICE_ACCOUNT_FILE=
GOOGLE_DELEGATED_USER=
GOOGLE_SHARED_CALENDAR_ID=
GOOGLE_SHARED_CALENDAR_NAME=Vencimientos – Estudio Contable
GOOGLE_CALENDAR_TIMEZONE=America/Argentina/Buenos_Aires
GOOGLE_CALENDAR_SCHEMA_VERSION=1

# CUIT autofill
AFIP_SDK_ACCESS_TOKEN=
AFIP_SDK_CUIT=20409378472
CUITALIZER_API_KEY=
# CUIT_LOOKUP_URL_TEMPLATE=https://tu-api.example/cuit/{cuit}
CUIT_LOOKUP_API_KEY=

# Security
CSRF_TRUSTED_ORIGINS=https://app.fabregad.com.ar,http://localhost:8000,http://127.0.0.1:8000
