# Coolify — variables para app.fabregad.com.ar
# Pegá estas en Environment Variables del servicio (no subir secretos al repo).

DEBUG=False
SECRET_KEY=GENERAR-UNA-CLAVE-LARGA-Y-ALEATORIA

ALLOWED_HOSTS=app.fabregad.com.ar
CSRF_TRUSTED_ORIGINS=https://app.fabregad.com.ar

APP_BASE_URL=https://app.fabregad.com.ar
APPLICATION_NAME=fabrenaque

# Postgres de Coolify (usar el que te genere el servicio DB)
DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/fabreapp

# Google OAuth
GOOGLE_OAUTH_CLIENT_ID=532044986614-mks0epv4gejni82p9qn8r5bivva88i35.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=PEGAR-SECRET-AQUI
GOOGLE_OAUTH_REDIRECT_URI=https://app.fabregad.com.ar/integraciones/google/callback/

GOOGLE_CALENDAR_ENABLED=False
GOOGLE_SHARED_CALENDAR_NAME=Vencimientos – Estudio Contable
GOOGLE_CALENDAR_TIMEZONE=America/Argentina/Buenos_Aires
GOOGLE_CALENDAR_SCHEMA_VERSION=1

# CUIT (opcional hasta configurar Afip SDK)
AFIP_SDK_ACCESS_TOKEN=
AFIP_SDK_CUIT=20409378472
